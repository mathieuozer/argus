FROM node:22-alpine AS builder
WORKDIR /app

COPY dashboard/package.json dashboard/package-lock.json* ./
RUN npm install

COPY dashboard/ .
RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY deployments/docker/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
